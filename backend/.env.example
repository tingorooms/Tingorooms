# Backend environment (Render)
NODE_ENV=production
PORT=10000
FRONTEND_URL=https://your-vercel-domain.vercel.app

# Database
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Image storage provider: imgbb or r2
IMAGE_STORAGE_PROVIDER=imgbb

# ImgBB configuration (used when IMAGE_STORAGE_PROVIDER=imgbb)
IMAGE_STORAGE_API_KEY=your_imgbb_key
IMAGE_STORAGE_URL=https://api.imgbb.com/1/upload

# Cloudflare R2 configuration (used when IMAGE_STORAGE_PROVIDER=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
# Optional: if R2 upload fails, fallback to ImgBB
IMAGE_STORAGE_FALLBACK_TO_IMGBB=true

# Email
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_brevo_login_email
SMTP_PASS=your_brevo_smtp_password
# Set to false only if your SMTP provider uses a self-signed cert (rare)
SMTP_TLS_REJECT_UNAUTHORIZED=true
# Set these to true after adding SPF and DKIM records on your DNS provider
SMTP_SPF_CONFIGURED=false
SMTP_DKIM_CONFIGURED=false
ADMIN_EMAIL=admin@example.com
SUPPORT_EMAIL=support@example.com
NOTIFICATION_EMAIL=notifications@example.com

# Web Push (required for notifications when browser/tab is closed)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@example.com

# Site branding and defaults
SITE_URL=https://your-vercel-domain.vercel.app
APP_NAME=RoomRental
BUSINESS_TAGLINE=Find Your Perfect Roommate
BUSINESS_LOGO_URL=
FAVICON_URL=
SUPPORT_PHONE=+91 99999 99999
BUSINESS_ADDRESS=Pune, Maharashtra
DEFAULT_CITY=Pune
FACEBOOK_URL=
TWITTER_URL=
INSTAGRAM_URL=
LINKEDIN_URL=
YOUTUBE_URL=
DEFAULT_AD_BG_SEARCH_URL=
DEFAULT_AD_BG_POST_URL=

# Upload limits and request protection
MAX_IMAGE_SIZE_KB=500
MAX_IMAGES_PER_ROOM=5
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
PUBLIC_RATE_LIMIT_WINDOW_MS=900000
PUBLIC_RATE_LIMIT_MAX_REQUESTS=300
REQUEST_TIMEOUT_MS=60000
REQUEST_BODY_LIMIT=2mb
TRUST_PROXY=1

# Keep-alive scheduler (prevents free-tier pause for DB/Supabase)
KEEP_ALIVE_CRON=15 3 * * *

# Better Stack / Logtail log drain
ENABLE_LOG_DRAIN=false
LOGTAIL_SOURCE_TOKEN=
# Alias for LOGTAIL_SOURCE_TOKEN (supported by code)
BETTER_STACK_SOURCE_TOKEN=
LOGTAIL_INGEST_URL=https://in.logs.betterstack.com

# Optional token gate for /api/startup/self-check endpoint
INTEGRATION_CHECK_TOKEN=
